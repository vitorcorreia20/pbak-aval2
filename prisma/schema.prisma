datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model TripRequest {
  id             String   @id @default(uuid())
  requesterName  String
  origin         String
  destination    String
  departureAt    DateTime
  returnAt       DateTime
  purpose        String
  passengerCount Int
  status         String   @default("pending") // Estados válidos: pending, canceled
  createdAt      DateTime @default(now())

  @@map("trip_requests") // Mapeamento da tabela em kebab/snake case internamente
}